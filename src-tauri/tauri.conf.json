{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Majestic Bytes",
  "version": "0.1.0",
  "identifier": "com.majestic.bytes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Majestic Bytes By Mk",
        "width": 1200,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Majestic World Studio",
    "icon": [
        "icons/icon.ico"
    ]
  }
}
